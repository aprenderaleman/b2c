# Copy to .env and adjust for your environment.

# Strong random string — used as API key for Evolution's HTTP API.
# Generate one with:  openssl rand -hex 32
EVOLUTION_API_KEY=change-me-to-a-long-random-string

# Strong random DB password.
EVOLUTION_DB_PASSWORD=change-me-too

# Port on the host.
EVOLUTION_PORT=8080

# Public URL (used by WhatsApp clients embedded in messages).
# Local dev:  http://localhost:8080
# Production: https://evolution.aprender-aleman.de
EVOLUTION_PUBLIC_URL=http://localhost:8080

# Where Evolution posts webhooks. In local dev this is the host machine;
# in production point it to the agents service reachable over the internet.
# Local dev:  http://host.docker.internal:8000/webhook/whatsapp
# Production: https://agents.aprender-aleman.de/webhook/whatsapp
AGENTS_WEBHOOK_URL=http://host.docker.internal:8000/webhook/whatsapp

# Production only (Caddy)
EVOLUTION_DOMAIN=evolution.aprender-aleman.de
